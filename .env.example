PORT=3000

# ─── Google Analytics 4 ───────────────────────────────────────────
# Property ID (numeric). Service account from Google Cloud must be
# added as a Viewer in GA4 admin → Property Access Management.
GA4_PROPERTY_ID=123456789
GA4_SERVICE_ACCOUNT_KEYFILE=/absolute/path/to/service-account.json

# Comma-separated event names treated as leads / activities in GA4.
LEAD_EVENTS=generate_lead,whatsapp_click,phone_click,email_click,telegram_click
ACTIVITY_EVENTS=generate_lead,instagram_click,whatsapp_click,phone_click,email_click,telegram_click,video_start,video_complete,read_more_click

# ─── Google Search Console ────────────────────────────────────────
# `sc-domain:` prefix for domain properties, full URL for URL properties.
# Add the GA4 service account as a user in GSC → Settings → Users
# and permissions (Restricted is enough).
GSC_SITE_URL=sc-domain:example.com
# Optional: separate keyfile for GSC if you don't want to reuse the GA4 one
# GSC_SERVICE_ACCOUNT_KEYFILE=/optional/separate/keyfile.json

# ─── Bright Data SERP API (Google + Yandex) ───────────────────────
# 1. Create a "SERP API" zone (Full JSON format) in the Bright Data
#    dashboard → https://brightdata.com/cp/zones
# 2. Copy the zone name into BRIGHT_DATA_SERP_ZONE.
# 3. Generate an API token at https://brightdata.com/cp/setting/users
#    and put it in BRIGHT_DATA_API_KEY.
BRIGHT_DATA_API_KEY=your-bright-data-bearer-token
BRIGHT_DATA_SERP_ZONE=serp_api1

# ─── SEO Progress (Google Sheet) ──────────────────────────────────
# ID from the sheet URL: docs.google.com/spreadsheets/d/<ID>/edit
# The sheet is parsed for Done/Not Done status in the last column of
# each tab to compute the SEO execution component of the index.
# Share the sheet with the service account (Viewer is enough).
SEO_PROGRESS_SHEET_ID=your-google-sheet-id
# Optional: separate keyfile for Sheets API
# SHEETS_SERVICE_ACCOUNT_KEYFILE=/optional/separate/keyfile.json

# ─── LLM narrative briefing (optional) ────────────────────────────
# When set, /api/briefing generates a natural-language summary of
# what changed since the previous snapshot using Claude.
# Get a key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-…
# ANTHROPIC_BRIEFING_MODEL=claude-opus-4-7

# ─── Bitrix24 CRM (leads + deals + pipeline) ─────────────────────
# Inbound webhook URL from Bitrix24:
#   1. In Bitrix24 admin → Developer resources → Other → Inbound webhook
#   2. Grant "CRM" scope
#   3. Copy the URL — looks like:
#      https://your-portal.bitrix24.ru/rest/<user_id>/<token>/
# Trailing slash optional; the dashboard appends <method>.json itself.
BITRIX_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/12/your-token/

# ─── Snapshot endpoint protection ─────────────────────────────────
# Bearer token required for POST /api/snapshot. Used by the weekly
# cron and `npm run snapshot`. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SNAPSHOT_TOKEN=generate-a-long-random-string
