PORT=3000

# Google Analytics 4
GA4_PROPERTY_ID=123456789
GA4_SERVICE_ACCOUNT_KEYFILE=/absolute/path/to/service-account.json
LEAD_EVENTS=generate_lead,request_price_click,whatsapp_click,phone_click,Phone_Click,email_click,Email_click,telegram_click
ACTIVITY_EVENTS=carousel_navigation_click,email_click,Email_click,generate_lead,instagram_click,learn_more_click,phone_click,Phone_Click,read_more_click,request_price_click,telegram_click,video_start,video_progress,video_complete,view_all_projects_click,whatsapp_click,youtube_click

# Google Search Console (uses GA4 service account by default)
GSC_SITE_URL=sc-domain:magnumestate.com
# GSC_SERVICE_ACCOUNT_KEYFILE=/optional/separate/keyfile.json

# Bright Data SERP API (Google + Yandex positions vs competitors)
# 1. Create a "SERP API" zone in Bright Data dashboard (https://brightdata.com/cp/zones)
# 2. Copy the zone name into BRIGHT_DATA_SERP_ZONE
# 3. Generate an API key at https://brightdata.com/cp/setting/users → BRIGHT_DATA_API_KEY
BRIGHT_DATA_API_KEY=your-bright-data-bearer-token
BRIGHT_DATA_SERP_ZONE=serp_api1

# SEO Progress (Google Sheet with content recommendations + Done/Not Done column)
SEO_PROGRESS_SHEET_ID=1XspRe32tt43uv2lpSZUwhV4tP3lZgGDE5oXPHk9uArM
# SHEETS_SERVICE_ACCOUNT_KEYFILE=/optional/separate/keyfile.json

# Snapshot endpoint protection (used by weekly cron + manual `npm run snapshot`)
SNAPSHOT_TOKEN=generate-a-long-random-string
