#!/usr/bin/env bash
# Pre-push guard: warn before pushing directly to main on origin.
# Override with `git push --no-verify` when intentional.

protected_branch="main"
remote="$1"

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/$protected_branch" ] && [ "$remote" = "origin" ]; then
    if [ -t 1 ]; then
      printf "\n\033[33m⚠  About to push directly to origin/main — this triggers production deploy.\033[0m\n"
      printf "Type 'deploy' to confirm, anything else to abort: "
      read -r answer < /dev/tty
      if [ "$answer" != "deploy" ]; then
        printf "\033[31m✗ push aborted\033[0m\n"
        exit 1
      fi
      printf "\033[32m✓ confirmed\033[0m\n"
    else
      printf "\n\033[31m✗ direct push to origin/main blocked (non-interactive shell).\nUse a feature branch + PR, or 'git push --no-verify' to override.\033[0m\n"
      exit 1
    fi
  fi
done

exit 0
